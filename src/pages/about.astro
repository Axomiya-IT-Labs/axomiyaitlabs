---
import BaseLayout from '../layouts/BaseLayout.astro';

const values = [
  {
    num: '01',
    en: 'From Scrolling to Creating',
    as: 'উপভোক্তাৰ পৰা সৃষ্টিকৰ্তালৈ',
    enBody: `Most people spend hours scrolling through things other people made. We help you turn that same curiosity into useful projects, small income paths, and real problem-solving. With AI assistants like ChatGPT, Copilot, and open-source models, you can start before you feel ready. No degree. No perfect English. Just one small build at a time.`,
    asBody: `বেছিভাগ মানুহে আনৰ বনোৱা বস্তু চাই ঘণ্টাৰ পিছত ঘণ্টা স্ক্ৰল কৰে। আমি সেই একে কৌতূহলক উপযোগী প্ৰকল্প, সৰু উপাৰ্জনৰ পথ আৰু বাস্তৱ সমস্যা সমাধানলৈ ঘূৰাই আনিবলৈ সহায় কৰোঁ। ChatGPT, Copilot আৰু মুক্ত-উৎস মডেলৰ দৰে AI সহায়কৰ সৈতে আপুনি সম্পূৰ্ণ প্ৰস্তুত অনুভৱ কৰাৰ আগতেই আৰম্ভ কৰিব পাৰে। ডিগ্ৰী নালাগে। নিখুঁত ইংৰাজী নালাগে। এটা সৰু নিৰ্মাণৰ পৰা আৰম্ভ কৰিলেই হয়।`,
    enCue: 'Start with something small enough to finish today.',
    asCue: 'আজিয়েই শেষ কৰিব পৰা এটা সৰু কামৰ পৰা আৰম্ভ কৰক।',
  },
  {
    num: '02',
    en: 'Open Source, Made Easier by AI',
    as: 'মুক্ত-উৎস, AIৰে শক্তিশালী',
    enBody: `Everything we make is free, transparent, and community-driven, built with contributors instead of only for users. AI reduces the hard parts: drafting docs, translating content, reviewing code, and finding bugs. That gives people more energy for ideas, judgment, and impact.`,
    asBody: `আমি নিৰ্মাণ কৰা সকলো বস্তু বিনামূলীয়া, স্বচ্ছ আৰু সম্প্ৰদায়-চালিত। কেৱল ব্যৱহাৰকাৰীৰ বাবে নহয়, অৱদানকাৰীৰ সৈতে মিলি নিৰ্মিত। AI কঠিন অংশবোৰ সহজ কৰে: নথিপত্ৰ লিখা, সমল অনুবাদ কৰা, ক'ড পৰ্যালোচনা কৰা আৰু ভুল বিচৰা। সেয়া মানুহক ধাৰণা, বিবেচনা আৰু প্ৰভাৱৰ বাবে অধিক শক্তি দিয়ে।`,
    enCue: 'You can contribute even if your first contribution is a correction.',
    asCue: 'আপোনাৰ প্ৰথম অৱদান কেৱল এটা সংশোধন হলেও মূল্যৱান।',
  },
  {
    num: '03',
    en: 'Assamese, by Default',
    as: 'স্বাভাৱিকতেই অসমীয়া',
    enBody: `Assam deserves world-class technology education in its own language. AI translation tools and language models help us build bilingual resources faster, so language does not decide who gets to learn. We build in Assamese first, then English, so every learner starts with confidence.`,
    asBody: `অসমে নিজৰ ভাষাত বিশ্বমানৰ প্ৰযুক্তি শিক্ষা পোৱাৰ অধিকাৰ আছে। AI অনুবাদ সঁজুলি আৰু ভাষা মডেলে আমাক দ্ৰুতভাৱে দ্বিভাষিক সম্পদ নিৰ্মাণ কৰাত সহায় কৰে, যাতে ভাষাই কোনে শিকিব পাৰিব সেইটো নিৰ্ধাৰণ নকৰে। আমি প্ৰথমে অসমীয়াত নিৰ্মাণ কৰোঁ, তাৰ পিছত ইংৰাজীত, যাতে প্ৰতিজন শিক্ষাৰ্থীয়ে আত্মবিশ্বাসেৰে আৰম্ভ কৰিব পাৰে।`,
    enCue: 'Understanding comes first. Speed comes after.',
    asCue: 'আগতে বুজি লোৱা। গতি তাৰ পিছত আহে।',
  },
];

const who = [
  { en: 'Kids', as: 'শিশু', href: '/contribute#students-beginners' },
  { en: 'Students', as: 'শিক্ষাৰ্থী', href: '/contribute#students-beginners' },
  { en: 'Teachers', as: 'শিক্ষক', href: '/contribute#teachers-parents-mentors' },
  { en: 'Parents', as: 'অভিভাৱক', href: '/contribute#teachers-parents-mentors' },
  { en: 'Developers', as: 'ডেভেলপাৰ', href: '/contribute#developers-engineers' },
  { en: 'Entrepreneurs', as: 'উদ্যোগী', href: '/contribute#professionals-freelancers-entrepreneurs' },
  { en: 'Freelancers', as: 'ফ্ৰীলেন্সাৰ', href: '/contribute#professionals-freelancers-entrepreneurs' },
  { en: 'Job Seekers', as: 'চাকৰি প্ৰাৰ্থী', href: '/contribute#students-beginners' },
  { en: 'Govt. Employees', as: 'চৰকাৰী কৰ্মচাৰী', href: '/contribute#professionals-freelancers-entrepreneurs' },
  { en: 'Small Businesses', as: 'ক্ষুদ্ৰ ব্যৱসায়ী', href: '/contribute#professionals-freelancers-entrepreneurs' },
  { en: 'Creators', as: 'সৃষ্টিকৰ্তা', href: '/contribute#designers-visual-creators' },
  { en: 'Lifelong Learners', as: 'আজীৱন শিক্ষাৰ্থী', href: '/contribute#students-beginners' },
];

const pillars = [
  {
    icon: '📖',
    en: 'Learn',
    as: 'শিকক',
    href: '/blog',
    enBody: `Read short guides, watch practical tutorials, and explore AI tools in plain Assamese and English. Each lesson is written to feel friendly, not intimidating, so beginners can keep going without getting bored.`,
    asBody: `চুটি নিৰ্দেশিকা পঢ়ক, ব্যৱহাৰিক টিউটৰিয়েল চাওক, আৰু সহজ অসমীয়া আৰু ইংৰাজীত AI সঁজুলি অন্বেষণ কৰক। প্ৰতিটো পাঠ ভয় লগা নহয়, আপোন যেন লগাকৈ লিখা, যাতে নতুন শিকাৰুৱেও বিৰক্ত নোহোৱাকৈ আগবাঢ়ি যাব পাৰে।`,
    enCue: 'Clear language lowers fear.',
    asCue: 'সহজ ভাষাই ভয় কমায়।',
  },
  {
    icon: '🔨',
    en: 'Build',
    as: 'নিৰ্মাণ কৰক',
    href: 'https://github.com/Axomiya-IT-Labs',
    external: true,
    enBody: `Create real projects: websites, AI tools, automation scripts, and educational platforms. We keep the steps visible and the code open, so people feel progress quickly and can improve what already exists.`,
    asBody: `প্ৰকৃত প্ৰকল্প নিৰ্মাণ কৰক: ৱেবছাইট, AI সঁজুলি, স্বয়ংক্ৰিয় স্ক্ৰিপ্ট আৰু শিক্ষামূলক প্লেটফৰ্ম। আমি পদক্ষেপবোৰ স্পষ্ট ৰাখোঁ আৰু ক'ড মুক্ত ৰাখোঁ, যাতে মানুহে সোনকালে অগ্ৰগতি অনুভৱ কৰে আৰু থকা বস্তু উন্নত কৰিব পাৰে।`,
    enCue: 'Visible progress keeps motivation alive.',
    asCue: 'দেখা অগ্ৰগতিয়ে উৎসাহ জীয়াই ৰাখে।',
  },
  {
    icon: '🤝',
    en: 'Share',
    as: 'শ্বেয়াৰ কৰক',
    href: 'https://www.facebook.com/groups/1556385872564016/',
    external: true,
    enBody: `Share what you learn, even if it feels small. Every translation, tutorial, example, bug report, and line of code removes friction for the next person and makes the community feel easier to enter.`,
    asBody: `আপুনি যি শিকে, সেয়া সৰু যেন লাগিলেও শ্বেয়াৰ কৰক। প্ৰতিটো অনুবাদ, টিউটৰিয়েল, উদাহৰণ, bug report আৰু ক'ডৰ প্ৰতিটো শাৰীয়ে পৰৱৰ্তী মানুহৰ বাধা কমায় আৰু সম্প্ৰদায়ত প্ৰৱেশ সহজ কৰি তোলে।`,
    enCue: 'Small help compounds.',
    asCue: 'সৰু সহায়েই ডাঙৰ প্ৰভাৱ গঢ়ে।',
  },
];

const missionEn = `We are here to collect precise information, make thoughtful analyses, present clear findings, add local context, and make all of it accessible to everyone in Assam — so that no one is left behind by international standards of technology and knowledge. If you want to share what you know, benefit others, and explore new fields with genuine curiosity, this is your community. Assam's first AI and open-source space — where everyone is welcome, whatever you do professionally.`;

const missionAs = `আমি ইয়াত আছোঁ সঠিক তথ্য সংগ্ৰহ কৰিবলৈ, চিন্তাশীল বিশ্লেষণ কৰিবলৈ, স্পষ্ট ফলাফল উপস্থাপন কৰিবলৈ, স্থানীয় প্ৰসঙ্গ যোগ কৰিবলৈ আৰু সেই সকলোকে অসমৰ প্ৰতিজন মানুহৰ বাবে সহজলভ্য কৰিবলৈ — যাতে প্ৰযুক্তি আৰু জ্ঞানৰ আন্তৰ্জাতিক মানদণ্ডত কোনো পিছপৰি নাথাকে। যদি আপুনি আপোনাৰ জ্ঞান শ্বেয়াৰ কৰিব বিচাৰে, আনৰ উপকাৰ কৰিব বিচাৰে, আৰু সত্যিকাৰ কৌতূহলেৰে নতুন ক্ষেত্ৰ অন্বেষণ কৰিব বিচাৰে — এইটোৱেই আপোনাৰ সম্প্ৰদায়। অসমৰ প্ৰথম AI আৰু মুক্ত-উৎসৰ পৰিসৰ — য'ত সকলোকে স্বাগতম, আপুনি পেশাদাৰীভাৱে যিয়েই কৰক।`;

const noteEn = `<a href="https://axomiya-it-labs.github.io" target="_blank" rel="noopener">Axomiya IT Labs</a> is a free and open-source community. Please do not use this space for business promotions, paid services, or commercial advertisements. All contributions must genuinely benefit the community. For business collaborations, sponsorships, or paid opportunities, please join our <a href="https://t.me/AxomiyaITLabs" target="_blank" rel="noopener">Telegram community</a> and speak directly with the admins.`;

const noteAs = `<a href="https://axomiya-it-labs.github.io" target="_blank" rel="noopener">Axomiya IT Labs</a> হৈছে এটা বিনামূলীয়া আৰু মুক্ত-উৎস সম্প্ৰদায়। অনুগ্ৰহ কৰি ব্যৱসায়িক প্ৰচাৰ, পেইড সেৱা বা বাণিজ্যিক বিজ্ঞাপনৰ বাবে এই পৰিসৰ ব্যৱহাৰ নকৰিব। সকলো অৱদানে সম্প্ৰদায়ক সত্যিকাৰভাৱে উপকৃত কৰা উচিত। ব্যৱসায়িক সহযোগিতা, প্ৰায়োজক বা পেইড সুযোগৰ বাবে আমাৰ <a href="https://t.me/AxomiyaITLabs" target="_blank" rel="noopener">টেলিগ্ৰাম সম্প্ৰদায়ত</a> যোগ দিয়ক আৰু সৰাসৰি এডমিনসকলৰ সৈতে কথা পাতক।`;
---

<BaseLayout
  title="About — Axomiya IT Labs"
  description="Assam's first AI and open-source community — building free tools, education, and software in Assamese and English. No expertise needed, just curiosity."
  active="about"
>
  <!-- ============ PAGE HEADER ============ -->
  <div class="page-header">
    <div class="wrap">
      <div class="tag" lang-en>About Us</div>
      <div class="tag" lang-as>আমাৰ বিষয়ে</div>
      <h1 lang-en>Assam's first AI &amp; open-source community.</h1>
      <h1 lang-as>অসমৰ প্ৰথম AI আৰু মুক্ত-উৎস সম্প্ৰদায়।</h1>
      <p lang-en>Everyone is welcome — no matter your age, background, or technical skill. If you are curious and want to learn, build, or share, you belong here.</p>
      <p lang-as>সকলোকে স্বাগতম — বয়স, পটভূমি বা প্ৰযুক্তিগত দক্ষতা যিয়েই নহওক। যদি আপুনি কৌতূহলী আৰু শিকিব, নিৰ্মাণ কৰিব বা শ্বেয়াৰ কৰিব বিচাৰে, আপুনি ইয়াতেই আপোনজন।</p>
    </div>
  </div>

  <div class="about-header-image">
    <img src="/assets/images/about-header.webp" alt="Axomiya IT Labs — Assam's open-source AI community" loading="lazy" decoding="async" />
  </div>

  <!-- ============ MISSION ============ -->
  <section>
    <div class="wrap">
      <div class="section-head center">
        <span class="tag" lang-en>Our Mission</span>
        <span class="tag" lang-as>আমাৰ লক্ষ্য</span>
        <h2 lang-en>The internet is the greatest free encyclopedia humanity has ever built.</h2>
        <h2 lang-as>ইণ্টাৰনেট হৈছে মানৱজাতিয়ে কেতিয়াও নিৰ্মাণ কৰা সৰ্বশ্ৰেষ্ঠ বিনামূলীয়া বিশ্বকোষ।</h2>
        <p lang-en>{missionEn}</p>
        <p lang-as>{missionAs}</p>
      </div>
    </div>
  </section>

  <!-- ============ LEARN BUILD SHARE ============ -->
  <section class="about-flow about-flow-soft">
    <div class="wrap">
      <div class="section-head center">
        <span class="tag" lang-en>What we do</span>
        <span class="tag" lang-as>আমি কি কৰোঁ</span>
        <h2 lang-en>Three words. One community.</h2>
        <h2 lang-as>তিনিটা শব্দ। এটা সম্প্ৰদায়।</h2>
      </div>
      <div class="values-list about-values-list">
        {
          pillars.map((p) => (
            <a
              href={p.href}
              target={p.external ? '_blank' : undefined}
              rel={p.external ? 'noopener' : undefined}
              class="value-card about-value-card about-link-card reveal"
              aria-label={`Open ${p.en}`}
            >
              <span class="num">{p.icon}</span>
              <div>
                <h3 lang-en>{p.en}</h3>
                <h3 lang-as>{p.as}</h3>
                <p lang-en>{p.enBody}</p>
                <p lang-as>{p.asBody}</p>
                <p class="micro-cue" lang-en>{p.enCue}</p>
                <p class="micro-cue" lang-as>{p.asCue}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ VALUES ============ -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <span class="tag" lang-en>What we believe</span>
        <span class="tag" lang-as>আমাৰ বিশ্বাস</span>
        <h2 lang-en>Three principles that guide everything we build.</h2>
        <h2 lang-as>তিনিটা নীতি যিয়ে আমাৰ প্ৰতিটো নিৰ্মাণক পথ দেখুৱায়।</h2>
      </div>
      <div class="values-list about-values-list principle-list">
        {
          values.map((v) => (
            <div class="value-card about-value-card reveal">
              <span class="num">{v.num}</span>
              <div>
                <h3 lang-en>{v.en}</h3>
                <h3 lang-as>{v.as}</h3>
                <p lang-en>{v.enBody}</p>
                <p lang-as>{v.asBody}</p>
                <p class="micro-cue" lang-en>{v.enCue}</p>
                <p class="micro-cue" lang-as>{v.asCue}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ WHO WE ARE FOR ============ -->
  <section style="background: var(--surface-soft); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="wrap">
      <div class="section-head center">
        <span class="tag" lang-en>Who this is for</span>
        <span class="tag" lang-as>এইটো কাৰ বাবে</span>
        <h2 lang-en>Built for every person in Assam — and beyond.</h2>
        <h2 lang-as>অসমৰ — আৰু তাৰ বাহিৰৰো — প্ৰতিজন মানুহৰ বাবে নিৰ্মিত।</h2>
        <p lang-en>You do not need to be a developer. You do not need to be an expert. If you are curious, you belong here. AI removes the barriers — we just need your willingness to explore and learn.</p>
        <p lang-as>আপুনি ডেভেলপাৰ হ'বলৈ নালাগে। আপুনি বিশেষজ্ঞ হ'বলৈ নালাগে। যদি আপুনি কৌতূহলী, আপুনি ইয়াতেই আপোনজন। AI বাধাসমূহ আঁতৰায় — আমাৰ দৰকাৰ কেৱল আপোনাৰ অন্বেষণ আৰু শিকিবলৈ ইচ্ছা।</p>
      </div>
      <div class="audience-cloud audience-cloud-linked">
        {
          who.map((w) => (
            <a href={w.href} class="audience-card reveal">
              <strong lang-en>{w.en}</strong>
              <strong lang-as>{w.as}</strong>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ OPEN SOURCE NOTE ============ -->
  <section class="contrib-note">
    <div class="wrap">
      <div class="note-card">
        <h3 lang-en>Open Source — Not Open for Business Promotions</h3>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';
import { projectFaqs } from '../../data/faq';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const projectFaq = projectFaqs[project.slug] || [];
const isComingSoon = project.status === 'coming-soon';

const projectJsonLd = {
  '@context': 'https://schema.org',
  '@type': isComingSoon ? 'CreativeWork' : 'SoftwareApplication',
  name: project.name.en,
  description: project.tagline.en,
  url: `${Astro.site}projects/${project.slug}`,
  author: {
    '@type': 'Organization',
    name: 'Axomiya IT Labs',
    url: Astro.site,
  },
};

const faqItemsForLd = projectFaq.map(item => ({
  question: item.question.en,
  answer: item.answer.en,
}));
---

<BaseLayout
  title={`${project.name.en} ${isComingSoon ? '(Coming Soon)' : ''} — Axomiya IT Labs`}
  description={project.tagline.en}
  active="projects"
  canonical={`${Astro.site}projects/${project.slug}`}
  faqItems={isComingSoon ? [] : faqItemsForLd}
>
  <script type="application/ld+json" set:html={JSON.stringify(projectJsonLd)} />

  <div class="page-header">
    <div class="wrap">
      <div class="breadcrumb">
        <a href="/projects" lang-en>← Back to Projects</a>
        <a href="/projects" lang-as>← প্ৰকল্পসমূহলৈ উভতি যাওক</a>
      </div>
      <div class="tag" lang-en>{project.tags[0]}</div>
      <div class="tag" lang-as>{project.tags[0]}</div>
      <h1 lang-en>{project.name.en}</h1>
      <h1 lang-as>{project.name.as}</h1>
      <p class="lead" lang-en>{project.tagline.en}</p>
      <p class="lead" lang-as>{project.tagline.as}</p>

      {isComingSoon ? (
        <div class="coming-soon-badge-wrap">
          <span class="status-badge coming-soon-lg">
            <span class="pulse-dot"></span>
            <span lang-en>Project Under Active Development — Launching Soon</span>
            <span lang-as>প্ৰকল্পৰ নিৰ্মাণ কাৰ্য চলি আছে — অতি সোনকালে উপলব্ধ হ'ব</span>
          </span>
        </div>
      ) : (
        <div class="project-hero-links">
          {project.website && (
            <a href={project.website} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
              <span lang-en>Visit Website →</span>
              <span lang-as>ৱেবছাইট চাওক →</span>
            </a>
          )}
          {project.github && (
            <a href={project.github} target="_blank" rel="noopener" class="btn btn-outline btn-lg">
              <span lang-en>View on GitHub</span>
              <span lang-as>GitHub ত চাওক</span>
            </a>
          )}
        </div>
      )}
    </div>
  </div>

  {project.image && (
    <div class="project-hero-image">
      <img src={project.image} alt={project.name.en} loading="lazy" />
    </div>
  )}

  {isComingSoon ? (
    <!-- ============ COMING SOON FULL DEDICATED PAGE STATE ============ -->
    <section class="coming-soon-detail-section">
      <div class="wrap">
        <div class="coming-soon-card">
          <div class="coming-soon-icon">🚀</div>
          <h2 lang-en>Coming Soon</h2>
          <h2 lang-as>আগলৈ আহিব</h2>
          
          <p class="coming-soon-desc" lang-en>
            <strong>{project.name.en}</strong> is currently being built by the Axomiya IT Labs community. 
            Detailed documentation, interactive demos, and source code repository links will be published here upon official release.
          </p>
          <p class="coming-soon-desc" lang-as>
            <strong>{project.name.as}</strong> বৰ্তমান অসমীয়া আই টি লেবছ সম্প্ৰদায়ৰ দ্বাৰা নিৰ্মাণ কৰি থকা হৈছে।
            আনুষ্ঠানিক মুকলিৰ পিছত ইয়াৰ বিস্তৃত নথিপত্ৰ, ডেম' আৰু মুক্ত-উৎস ক'ড ৰিপ'জিটৰী লিংকসমূহ ইয়াত প্ৰকাশ কৰা হ'ব।
          </p>

          <div class="coming-soon-highlights">
            <div class="highlight-item">
              <strong lang-en>Overview</strong>
              <strong lang-as>বিৱৰণ</strong>
              <p lang-en>{project.purpose.en}</p>
              <p lang-as>{project.purpose.as}</p>
            </div>
            <div class="highlight-item">
              <strong lang-en>Planned Features</strong>
              <strong lang-as>পৰিকল্পিত বৈশিষ্ট্যসমূহ</strong>
              <p lang-en>{project.features.en}</p>
              <p lang-as>{project.features.as}</p>
            </div>
          </div>

          <div class="coming-soon-actions">
            <a href="https://t.me/AxomiyaITLabs" target="_blank" rel="noopener" class="btn btn-primary btn-lg">
              <span lang-en>Get Notified on Telegram →</span>
              <span lang-as>টেলিগ্ৰামত আপডেট পাওক →</span>
            </a>
            <a href="/contribute" class="btn btn-outline btn-lg">
              <span lang-en>Help Us Build It</span>
              <span lang-as>নিৰ্মাণত সহায় কৰক</span>
            </a>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <!-- ============ LIVE PROJECT WIKI STATE ============ -->
    <>
      <section class="project-wiki">
        <div class="wrap">
          <div class="project-wiki-grid">
            <div class="project-wiki-main">
              <div class="wiki-section">
                <h2 lang-en>What it is</h2>
                <h2 lang-as>এইটো কি</h2>
                <p lang-en>{project.purpose.en}</p>
                <p lang-as>{project.purpose.as}</p>
              </div>
              <div class="wiki-section">
                <h2 lang-en>What's inside</h2>
                <h2 lang-as>ভিতৰত কি আছে</h2>
                <p lang-en>{project.features.en}</p>
                <p lang-as>{project.features.as}</p>
              </div>
              {project.future && (
                <div class="wiki-section">
                  <h2 lang-en>Future improvements</h2>
                  <h2 lang-as>ভৱিষ্যত উন্নতিসমূহ</h2>
                  <p lang-en>{project.future.en}</p>
                  <p lang-as>{project.future.as}</p>
                </div>
              )}
            </div>
            <aside class="project-wiki-sidebar">
              <div class="wiki-card">
                <h3 lang-en>Project Info</h3>
                <h3 lang-as>প্ৰকল্প তথ্য</h3>
                <div class="wiki-meta-item">
                  <span lang-en>Status</span>
                  <span class="status-badge live">Live</span>
                </div>
                <div class="wiki-meta-item">
                  <span lang-en>Category</span>
                  <span>{project.tags.join(', ')}</span>
                </div>
                <div class="wiki-meta-item">
                  <span lang-en>License</span>
                  <span>MIT License</span>
                </div>
              </div>
              <div class="wiki-card wiki-contribute-card">
                <h3 lang-en>Contribute</h3>
                <h3 lang-as>অৱদান আগবঢ়াওক</h3>
                <p lang-en>Found a bug? Have a feature idea? We welcome all contributions.</p>
                <p lang-as>ভুল পাইছে? নতুন বৈশিষ্ট্যৰ ধাৰণা আছে? আমি সকলো অৱদানক স্বাগতম জনাওঁ।</p>
                <a href="/contribute" class="btn btn-primary btn-sm">
                  <span lang-en>Start Contributing</span>
                  <span lang-as>অৱদান আৰম্ভ কৰক</span>
                </a>
              </div>
            </aside>
          </div>
        </div>
      </section>

      {projectFaq.length > 0 && (
        <section class="faq-section">
          <div class="wrap">
            <div class="section-head">
              <span class="tag" lang-en>FAQ</span>
              <span class="tag" lang-as>সাধাৰণ প্ৰশ্ন</span>
              <h2 lang-en>Frequently asked questions about {project.name.en}</h2>
              <h2 lang-as>{project.name.en}ৰ বিষয়ে প্ৰশ্নোত্তৰ</h2>
            </div>
            <div class="faq-list">
              {projectFaq.map((item) => (
                <details class="faq-item">
                  <summary>
                    <h3 lang-en>{item.question.en}</h3>
                    <h3 lang-as>{item.question.as}</h3>
                    <span class="faq-toggle" aria-hidden="true">+</span>
                  </summary>
                  <div class="faq-answer">
                    <p lang-en>{item.answer.en}</p>
                    <p lang-as>{item.answer.as}</p>
                  </div>
                </details>
              ))}
            </div>
          </div>
        </section>
      )}

      <section class="project-bottom-cta">
        <div class="wrap">
          <h2 lang-en>Ready to explore?</h2>
          <h2 lang-as>অন্বেষণ কৰিবলৈ প্ৰস্তুত?</h2>
          <p lang-en>Visit the live project or check out the source code on GitHub.</p>
          <p lang-as>চলিত প্ৰকল্প চাওক বা GitHub ত ক'ড চাওক।</p>
          <div class="project-bottom-links">
            {project.website && (
              <a href={project.website} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
                <span lang-en>Visit Website →</span>
                <span lang-as>ৱেবছাইট চাওক →</span>
              </a>
            )}
            {project.github && (
              <a href={project.github} target="_blank" rel="noopener" class="btn btn-outline btn-lg">
                <span lang-en>View on GitHub</span>
                <span lang-as>GitHub ত চাওক</span>
              </a>
            )}
          </div>
        </div>
      </section>
    </>
  )}
</BaseLayout>

<style>
  .coming-soon-badge-wrap {
    margin-top: 24px;
    display: flex;
    justify-content: center;
  }
  .coming-soon-lg {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 30px;
    background: rgba(245, 158, 11, 0.12);
    color: #fbbf24;
    border: 1px solid rgba(245, 158, 11, 0.3);
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #fbbf24;
    box-shadow: 0 0 10px #fbbf24;
    animation: pulse 1.8s infinite;
  }
  @keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(251, 191, 36, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 8px rgba(251, 191, 36, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(251, 191, 36, 0); }
  }
  .coming-soon-detail-section {
    padding: 60px 0 100px 0;
  }
  .coming-soon-card {
    max-width: 800px;
    margin: 0 auto;
    background: var(--surface-soft, rgba(255, 255, 255, 0.03));
    border: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    border-radius: 20px;
    padding: 48px 40px;
    text-align: center;
  }
  .coming-soon-icon {
    font-size: 3.5rem;
    margin-bottom: 16px;
  }
  .coming-soon-card h2 {
    font-size: 2.2rem;
    margin-bottom: 20px;
    color: var(--text-primary, #ffffff);
  }
  .coming-soon-desc {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary, #cbd5e1);
    margin-bottom: 36px;
  }
  .coming-soon-highlights {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 40px;
    text-align: left;
  }
  @media (max-width: 640px) {
    .coming-soon-highlights {
      grid-template-columns: 1fr;
    }
  }
  .highlight-item {
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 24px;
    border-radius: 12px;
  }
  .highlight-item strong {
    font-size: 1rem;
    color: var(--brand-primary, #6366f1);
    margin-bottom: 8px;
  }
  .highlight-item p {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-secondary, #94a3b8);
    line-height: 1.5;
  }
  .coming-soon-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }
</style>

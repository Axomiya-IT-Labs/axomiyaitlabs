---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

const live = projects.filter((p) => p.status === 'live');
const comingSoon = projects.filter((p) => p.status === 'coming-soon');
---

<BaseLayout
  title="Projects — Axomiya IT Labs"
  description="Open-source projects built for Assam — tools, AI apps, finance guides, and career platforms in Assamese and English."
  active="projects"
>
  <div class="page-header">
    <div class="wrap">
      <div class="tag" lang-en>Projects</div>
      <div class="tag" lang-as>প্ৰকল্পসমূহ</div>
      <h1 lang-en>What we have built, are building, and dream of building.</h1>
      <h1 lang-as>আমি নিৰ্মাণ কৰা, নিৰ্মাণ কৰি আছোঁ, আৰু নিৰ্মাণ কৰাৰ স্বপ্ন পোৱা বস্তু।</h1>
      <p lang-en>Every project is open source, free to use, and built for the Assamese community — by the community. AI helps us move faster and make everything accessible.</p>
      <p lang-as>প্ৰতিটো প্ৰকল্পও মুক্ত-উৎস, বিনামূলীয়া ব্যৱহাৰযোগ্য, আৰু অসমীয়া সম্প্ৰদায়ৰ বাবে নিৰ্মিত — সম্প্ৰদায় দ্ৱাৰা। AI আমাক দ্ৰুত আগবঢ়াবলৈ আৰু সকলো সহজলভ্য কৰিবলৈ সহায় কৰে।</p>
    </div>
  </div>

  <div class="projects-header-image">
    <img src="/assets/images/projects-header.webp" alt="Axomiya IT Labs Projects" loading="lazy" />
  </div>

  <!-- ============ LIVE PROJECTS ============ -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <span class="tag" lang-en>Live Projects</span>
        <span class="tag" lang-as>চলিত প্ৰকল্প</span>
        <h2 lang-en>Ready to use today.</h2>
        <h2 lang-as>আজি ব্যৱহাৰৰ বাবে প্ৰস্তুত।</h2>
      </div>
      <div class="projects-grid">
        {
          live.map((p) => (
            <article class="project-card reveal" data-status={p.status}>
              <a href={`/projects/${p.slug}`} class="project-card-inner">
                <div class="project-thumb">
                  {p.image && <img src={p.image} alt={p.name.en} loading="lazy" />}
                </div>
                <div class="project-header">
                  <div class="project-tags">
                    {p.tags.map((t) => <span class="tag-pill">{t}</span>)}
                  </div>
                  <span class="status-badge live">Live</span>
                </div>
                <h3 lang-en>{p.name.en}</h3>
                <h3 lang-as>{p.name.as}</h3>
                <p class="tagline" lang-en>{p.tagline.en}</p>
                <p class="tagline" lang-as>{p.tagline.as}</p>
                <div class="project-body">
                  <div class="project-detail">
                    <strong lang-en>What it is</strong>
                    <strong lang-as>এইটো কি</strong>
                    <p lang-en>{p.purpose.en}</p>
                    <p lang-as>{p.purpose.as}</p>
                  </div>
                  <div class="project-detail">
                    <strong lang-en>What's inside</strong>
                    <strong lang-as>ভিতৰত কি আছে</strong>
                    <p lang-en>{p.features.en}</p>
                    <p lang-as>{p.features.as}</p>
                  </div>
                </div>
                <div class="project-card-cta">
                  <span class="cta-text" lang-en>Read full wiki →</span>
                  <span class="cta-text" lang-as>সম্পূৰ্ণ wiki পঢ়ক →</span>
                </div>
              </a>
              <div class="project-external-links">
                {p.website && (
                  <a href={p.website} target="_blank" rel="noopener" class="btn btn-primary btn-sm">
                    <span lang-en>Visit Website</span>
                    <span lang-as>ৱেবছাইট চাওক</span>
                  </a>
                )}
                {p.github && (
                  <a href={p.github} target="_blank" rel="noopener" class="btn btn-outline btn-sm">
                    <span lang-en>View on GitHub</span>
                    <span lang-as>GitHub ত চাওক</span>
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ COMING SOON ============ -->
  <section style="background: var(--surface-soft); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="wrap">
      <div class="section-head">
        <span class="tag" lang-en>Coming Soon</span>
        <span class="tag" lang-as>আগলৈ আহিব</span>
        <h2 lang-en>We are working on these — stay tuned.</h2>
        <h2 lang-as>আমি এইসমূহত কাম কৰি আছোঁ — লগতে থাকক।</h2>
      </div>
      <div class="projects-grid">
        {
          comingSoon.map((p) => (
            <article class="project-card reveal idea-card" data-status={p.status}>
              <a href={`/projects/${p.slug}`} class="project-card-inner">
                <div class="project-thumb">
                  {p.image && <img src={p.image} alt={p.name.en} loading="lazy" />}
                </div>
                <div class="project-header">
                  <div class="project-tags">
                    {p.tags.map((t) => <span class="tag-pill">{t}</span>)}
                  </div>
                  <span class="status-badge coming-soon">Coming Soon</span>
                </div>
                <h3 lang-en>{p.name.en}</h3>
                <h3 lang-as>{p.name.as}</h3>
                <p class="tagline" lang-en>{p.tagline.en}</p>
                <p class="tagline" lang-as>{p.tagline.as}</p>
                <div class="project-body">
                  <div class="project-detail">
                    <strong lang-en>What it is</strong>
                    <strong lang-as>এইটো কি</strong>
                    <p lang-en>{p.purpose.en}</p>
                    <p lang-as>{p.purpose.as}</p>
                  </div>
                  <div class="project-detail">
                    <strong lang-en>What's inside</strong>
                    <strong lang-as>ভিতৰত কি আছে</strong>
                    <p lang-en>{p.features.en}</p>
                    <p lang-as>{p.features.as}</p>
                  </div>
                </div>
                <div class="project-card-cta">
                  <span class="cta-text" lang-en>Coming Soon →</span>
                  <span class="cta-text" lang-as>আগলৈ আহিব →</span>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============ CONTRIBUTE CTA ============ -->
  <section class="join-strip" id="join">
    <div class="wrap">
      <h2 lang-en>If you want, you can contribute.</h2>
      <h2 lang-as>যদি আপুনি চায়, আপুনি অৱদান আগবঢ়াব পাৰে।</h2>
      <p lang-en>No matter who you are — student, professional, kid, or lifelong learner — there is a place for you here. Everyone can contribute.</p>
      <p lang-as>আপুনি যিয়েই হওক — শিক্ষাৰ্থী, পেশাদাৰ, শিশু, বা আজীৱন শিক্ষাৰ্থী — ইয়াত আপোনাৰ বাবে স্থান আছে। প্ৰতিজনে অৱদান আগবঢ়াব পাৰে।</p>
      <div class="join-links">
        <a href="/contribute" class="btn btn-primary">
          <span lang-en>Start Contributing →</span>
          <span lang-as>অৱদান আৰম্ভ কৰক →</span>
        </a>
        <a href="https://t.me/AxomiyaITLabs" target="_blank" rel="noopener" class="tg">
          <span lang-en><img src="/assets/icons/telegram.svg" alt="" width="18" height="18" /> Telegram Community</span>
          <span lang-as><img src="/assets/icons/telegram.svg" alt="" width="18" height="18" /> টেলিগ্ৰাম সম্প্ৰদায়</span>
        </a>
        <a href="https://www.facebook.com/groups/1556385872564016/" target="_blank" rel="noopener" class="fb">
          <span lang-en><img src="/assets/icons/facebook.svg" alt="" width="18" height="18" /> Facebook Group</span>
          <span lang-as><img src="/assets/icons/facebook.svg" alt="" width="18" height="18" /> ফেচবুক গ্ৰুপ</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

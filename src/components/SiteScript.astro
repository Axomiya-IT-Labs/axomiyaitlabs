<script>
  /* ---------- Language toggle (EN / অসমীয়া) ---------- */
  const root = document.documentElement;
  const STORAGE_KEY = 'ail-lang';

  function setLang(lang: string) {
    root.setAttribute('data-lang', lang);
    try {
      localStorage.setItem(STORAGE_KEY, lang);
    } catch (_) {}
    document.querySelectorAll<HTMLButtonElement>('.lang-toggle button').forEach((btn) => {
      btn.classList.toggle('is-active', btn.dataset.lang === lang);
    });
    document.querySelectorAll<HTMLElement>('[data-lang-label]').forEach((el) => {
      el.textContent = lang === 'as' ? el.dataset.asLabel! : el.dataset.enLabel!;
    });
  }

  try {
    const savedLang = localStorage.getItem(STORAGE_KEY) || 'en';
    setLang(savedLang);
  } catch (_) {
    setLang('en');
  }

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.lang-toggle button');
    if (btn) setLang(btn.dataset.lang!);
  });

  /* ---------- Mobile nav with auto-close on link click ---------- */
  function initMobileNav() {
    const navToggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
    const mainNav = document.querySelector<HTMLElement>('.main-nav');
    if (!navToggle || !mainNav) return;

    function closeNav() {
      mainNav!.classList.remove('is-open');
      navToggle!.classList.remove('is-open');
      navToggle!.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    navToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = mainNav.classList.toggle('is-open');
      navToggle.classList.toggle('is-open', open);
      navToggle.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
    });

    // Dismiss automatically when clicking ANY menu link
    mainNav.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) {
        closeNav();
      }
    });

    // Dismiss when clicking outside the navbar
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!mainNav.contains(target) && !navToggle.contains(target) && mainNav.classList.contains('is-open')) {
        closeNav();
      }
    });

    // Close on Escape key press
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && mainNav.classList.contains('is-open')) {
        closeNav();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileNav);
  } else {
    initMobileNav();
  }

  /* ---------- Marquee: duplicate track for seamless loop ---------- */
  document.querySelectorAll('.marquee-track').forEach((track) => {
    if (track.children.length && track.children.length < 20) {
      track.innerHTML += track.innerHTML;
    }
  });

  /* ---------- Reveal-on-scroll ---------- */
  const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
  if ('IntersectionObserver' in window && revealEls.length) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    revealEls.forEach((el) => io.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add('is-visible'));
  }

  /* ---------- Blog: category filter + search (blog page only) ---------- */
  const filterBar = document.querySelector<HTMLElement>('.blog-filter');
  const searchInput = document.querySelector<HTMLInputElement>('.blog-search input');
  const cards = document.querySelectorAll<HTMLElement>('.blog-card');

  function applyBlogFilters() {
    const activeBtn = filterBar ? filterBar.querySelector<HTMLButtonElement>('button.is-active') : null;
    const cat = activeBtn ? activeBtn.dataset.cat : 'all';
    const q = searchInput ? searchInput.value.trim().toLowerCase() : '';

    cards.forEach((card) => {
      const matchesCat = cat === 'all' || card.dataset.cat === cat;
      const text = card.innerText.toLowerCase();
      const matchesSearch = !q || text.includes(q);
      card.style.display = matchesCat && matchesSearch ? '' : 'none';
    });
  }

  if (filterBar) {
    filterBar.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('button');
      if (!btn) return;
      filterBar.querySelectorAll('button').forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      applyBlogFilters();
    });
  }
  if (searchInput) {
    searchInput.addEventListener('input', applyBlogFilters);
  }

  /* ---------- Footer year ---------- */
  document.querySelectorAll('.year').forEach((el) => {
    el.textContent = String(new Date().getFullYear());
  });

  /* ---------- FAQ accordion: only one answer visible at a time ---------- */
  const faqItems = document.querySelectorAll<HTMLDetailsElement>('.faq-item');
  faqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (item.open) {
        faqItems.forEach((other) => {
          if (other !== item && other.open) {
            other.open = false;
          }
        });
      }
    });
  });
</script>

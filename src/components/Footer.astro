---
const social = [
  { href: 'https://facebook.com/AxomiyaITLabs', label: 'Facebook', icon: '/assets/icons/facebook.svg' },
  { href: 'https://github.com/Axomiya-IT-Labs', label: 'GitHub', icon: '/assets/icons/github.svg' },
  { href: 'https://x.com/AxomiyaIndie', label: 'X / Twitter', icon: '/assets/icons/x.svg' },
  { href: 'https://www.youtube.com/@AxomiyaITLabs', label: 'YouTube', icon: '/assets/icons/youtube.svg' },
  { href: 'https://www.instagram.com/axomiyaitlabs', label: 'Instagram', icon: '/assets/icons/instagram.svg' },
  { href: 'https://www.linkedin.com/company/axomiya-it-labs', label: 'LinkedIn', icon: '/assets/icons/linkedin.svg' },
];

const explore = [
  { href: '/about', en: 'About', as: 'আমাৰ বিষয়ে' },
  { href: '/what-we-build', en: 'What We Build', as: 'আমি কি নিৰ্মাণ কৰোঁ' },
  { href: '/projects', en: 'Projects', as: 'প্ৰকল্পসমূহ' },
  { href: '/blog', en: 'Blog', as: 'ব্লগ' },
  { href: '/contribute', en: 'Contribute', as: 'অৱদান আগবঢ়াওক' },
];

const community = [
  { href: 'https://www.facebook.com/groups/1556385872564016/', en: 'Facebook Group', as: 'ফেচবুক গ্ৰুপ' },
  { href: 'https://t.me/AxomiyaITLabs', en: 'Telegram Community', as: 'টেলিগ্ৰাম সম্প্ৰদায়' },
  { href: '#discord', en: 'Discord Server', as: 'ডিচক\'ৰ্ড চাৰ্ভাৰ' },
];

const legal = [
  { href: 'https://github.com/Axomiya-IT-Labs/axomiyaitlabs/blob/main/LICENSE', en: 'MIT License', as: 'MIT লাইচেন্স' },
  { href: '/code-of-conduct', en: 'Code of Conduct', as: 'আচাৰ সংহিতা' },
  { href: 'mailto:axomiyaitlabs@gmail.com', en: 'Contact', as: 'যোগাযোগ' },
];
---

<footer>
  <div class="wrap">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="brand">
          
          <span>Axomiya IT Labs</span>
        </a>
        <p lang-en>
          Equal access for all. Making AI easy for everyone in Assam &amp; beyond. Everything open
          source, free forever.
        </p>
        <p lang-as>
          সকলোৰে বাবে সমান সুযোগ। অসম আৰু তাৰোপৰি সকলোৰে বাবে AI সহজ কৰি তোলা। সকলো মুক্ত-উৎস, চিৰদিনৰ বাবে বিনামূলীয়া।
        </p>
        <div class="social-row">
          {
            social.map((s) => (
              <a href={s.href} target="_blank" rel="noopener" aria-label={s.label}>
                {s.icon.endsWith('.svg') ? (
                  <img src={s.icon} alt={s.label} width="18" height="18" />
                ) : (
                  s.icon
                )}
              </a>
            ))
          }
        </div>
      </div>

      <div class="footer-col">
        <h4 lang-en>Explore</h4>
        <h4 lang-as>অন্বেষণ কৰক</h4>
        <ul>
          {
            explore.map((l) => (
              <li>
                <a href={l.href} lang-en>
                  {l.en}
                </a>
                <a href={l.href} lang-as>
                  {l.as}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-col">
        <h4 lang-en>Community</h4>
        <h4 lang-as>সম্প্ৰদায়</h4>
        <ul>
          {
            community.map((l) => (
              <li>
                <a href={l.href} target="_blank" rel="noopener" lang-en>
                  {l.en}
                </a>
                <a href={l.href} target="_blank" rel="noopener" lang-as>
                  {l.as}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-col">
        <h4 lang-en>Legal</h4>
        <h4 lang-as>আইনী</h4>
        <ul>
          {
            legal.map((l) => (
              <li>
                <a href={l.href} lang-en>
                  {l.en}
                </a>
                <a href={l.href} lang-as>
                  {l.as}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span lang-en>© <span class="year">2026</span> Axomiya IT Labs. Made with ❤️ from Assam 🇮🇳</span>
      <span lang-as>© <span class="year">2026</span> Axomiya IT Labs। অসমৰ পৰা ❤️ ৰে নিৰ্মিত 🇮🇳</span>
      <span>জয় আই অসম</span>
    </div>
  </div>
</footer>

---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SiteScript from '../components/SiteScript.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  active?: string;
  canonical?: string;
  faqItems?: Array<{ question: string; answer: string }>;
}

const {
  title,
  description = 'Axomiya IT Labs builds free, open-source AI tools, education, and software — in Assamese and English. Learn, build, and share — no expertise required.',
  ogImage = '/assets/images/og-image.png',
  active = 'home',
  canonical,
  faqItems,
} = Astro.props;

const pageUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const siteName = 'Axomiya IT Labs';
const ogImageFull = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: siteUrl,
  logo: `${siteUrl}/assets/images/logo.svg`,
  description: 'Assam\'s first AI and open-source community — building free tools, education, and software in Assamese and English.',
  sameAs: [
    'https://github.com/axomiyaindie',
    'https://t.me/AxomiyaITLabs',
    'https://www.facebook.com/groups/1556385872564016/',
  ],
  foundingLocation: {
    '@type': 'Place',
    name: 'Assam, India',
  },
};

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  description,
  inLanguage: ['en', 'as'],
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const faqJsonLd = faqItems && faqItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
} : null;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Axomiya IT Labs, Assamese technology, open source Assam, AI tools Assamese, free AI education, Assam developers, অসমীয়া প্ৰযুক্তি, মুক্ত-উৎস অসম, AI শিক্ষা" />
    <meta name="author" content="Axomiya IT Labs" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0f172a" />
    <meta name="google-site-verification" content="A8wskx8nC830MPRqphjcUgeBznTKVkFUWtD_EwGqEo8" />
    <link rel="canonical" href={pageUrl} />

    <!-- Favicon -->
    <link rel="icon" href="/assets/images/open-icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/assets/images/logo.svg" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageFull} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteName} — ${description}`} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="as_IN" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@AxomiyaITLabs" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageFull} />
    <meta name="twitter:image:alt" content={`${siteName} preview`} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

    <!-- Perf: JS class swap -->
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body class="no-js">
    <div class="grain" aria-hidden="true"></div>
    <Header active={active} />
    <main>
      <slot />
    </main>
    <Footer />
    <SiteScript />
  </body>
</html>
